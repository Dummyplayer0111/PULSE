# ── Twilio SMS (Customer Notifications) ──────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (E.164 format)
# Use +15005550006 for Twilio test credentials (no real SMS sent)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# The demo recipient number — simulates the ATM customer's registered mobile
# Replace with your own phone number to receive live SMS during demo
DEMO_CUSTOMER_PHONE=+91XXXXXXXXXX

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
