  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "target": "es6",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "remotion.config.ts"]
}
